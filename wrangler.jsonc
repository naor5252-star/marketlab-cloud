{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "marketlab-cloud",
  "main": "src/worker.js",
  "compatibility_date": "2026-07-16",
  "workers_dev": true,
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*", "/auth/*", "/login", "/logout", "/import", "/healthz"]
  },
  "vars": {
    "APP_VERSION": "2.1.0",
    "OPENAI_MODEL": "gpt-5.6-luna"
  },
  "observability": {
    "enabled": true
  }
}
